{
  "name": "@argusaudit/cli",
  "version": "0.2.1",
  "description": "ARGUS — SQL Stress-Test Auditor. Benchmark-as-a-Service CLI tool that proves SQL optimizations with hard numbers.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "argus": "./dist/bin/argus.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && cp src/lib/worker-compose.yml dist/src/lib/worker-compose.yml",
    "dev": "pnpm run build && node --env-file-if-exists=.env.local dist/bin/argus.js",
    "prepublishOnly": "pnpm run build",
    "test": "node --test",
    "lint": "eslint ."
  },
  "keywords": [
    "sql",
    "benchmark",
    "performance",
    "postgres",
    "audit",
    "optimization"
  ],
  "author": "the-mzakrzewski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-mzakrzewski/argus-cli.git"
  },
  "homepage": "https://github.com/the-mzakrzewski/argus-cli#readme",
  "bugs": {
    "url": "https://github.com/the-mzakrzewski/argus-cli/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.7.0",
  "dependencies": {
    "@napi-rs/keyring": "1.3.0",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "js-yaml": "5.2.1",
    "open": "11.0.0",
    "ora": "9.4.1",
    "undici": "8.7.0"
  },
  "devDependencies": {
    "@types/js-yaml": "4.0.9",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "typescript": "7.0.2"
  }
}
